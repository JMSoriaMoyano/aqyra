{
  "name": "@aqyra/root",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "build": "pnpm -r --filter ./visor --filter ./openbim --filter ./embed build",
    "licenses": "license-checker --production --excludePrivatePackages --onlyAllow \"MIT;Apache-2.0;MPL-2.0;ISC;BSD-2-Clause;BSD-3-Clause;CC0-1.0;0BSD;Unlicense\"",
    "e2e:build": "vite build -c e2e/vite.config.ts && cp node_modules/web-ifc/web-ifc*.wasm e2e/dist/",
    "e2e:test": "playwright test -c e2e/playwright.config.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "jsdom": "^24.1.1",
    "vite": "^5.4.0",
    "license-checker": "^25.0.1",
    "@playwright/test": "^1.47.0"
  }
}
