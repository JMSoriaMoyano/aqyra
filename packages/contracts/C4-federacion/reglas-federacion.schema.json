{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aqyra.dev/contracts/C4/reglas-federacion.schema.json",
  "title": "C4 · reglas de federación (entrada de federar)",
  "description": "Entrada de C4: cómo llevar N IFC por disciplina a un sistema de referencia común y componer el Maestro. ADR: EPSG + punto base DECLARADO por modelo, nunca adivinado. Forward-open: se AÑADEN claves, nunca se cambia la semántica de las existentes.",
  "type": "object",
  "required": ["proyecto", "crs_destino", "modelos"],
  "additionalProperties": true,
  "properties": {
    "proyecto": { "type": "string", "minLength": 1 },
    "crs_destino": { "$ref": "#/$defs/crs" },
    "modelos": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/modelo" } },
    "deduplicacion": { "$ref": "#/$defs/deduplicacion" },
    "ids_pack": { "$ref": "#/$defs/ids_pack" }
  },
  "$defs": {
    "crs": {
      "type": "object",
      "required": ["epsg"],
      "additionalProperties": true,
      "properties": {
        "epsg": { "type": "string", "pattern": "^EPSG:[0-9]{4,6}$" },
        "descripcion": { "type": "string" },
        "datum_vertical": { "type": "string" }
      }
    },
    "punto_base": {
      "description": "Punto base DECLARADO (ADR): dónde se ancla el origen local del modelo en el CRS destino. 'declarado_por' deja constancia de quién lo fijó — nunca se infiere en silencio.",
      "type": "object",
      "required": ["e", "n", "cota"],
      "additionalProperties": true,
      "properties": {
        "e": { "type": "number" },
        "n": { "type": "number" },
        "cota": { "type": "number" },
        "rotacion_deg": { "type": "number", "default": 0.0 },
        "declarado_por": { "type": "string" }
      }
    },
    "modelo": {
      "type": "object",
      "required": ["id", "disciplina", "fichero", "punto_base"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "disciplina": { "type": "string", "minLength": 1, "$comment": "abierto (ARQ, EST, MEP, OBRA-LINEAL, ...); no enum para no cerrar el catálogo" },
        "fichero": { "type": "string", "minLength": 1 },
        "md5": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
        "crs_origen": {
          "oneOf": [ { "$ref": "#/$defs/crs" }, { "type": "null" } ],
          "$comment": "null = el modelo NO viene georreferenciado; el punto_base declarado manda (ADR)"
        },
        "punto_base": { "$ref": "#/$defs/punto_base" },
        "estado_entrada": { "$ref": "#/$defs/estado_s" },
        "prioridad": { "type": "integer", "minimum": 1, "$comment": "orden de resolución al unificar la estructura espacial" }
      }
    },
    "deduplicacion": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "elementos": {
          "type": "string", "enum": ["nunca"],
          "$comment": "v0.1: los elementos NO se deduplican — procedencia y GUIDs de terceros se preservan (ADR). Valores futuros ampliarán el enum (forward-open)."
        },
        "estructura_espacial": {
          "type": "string", "enum": ["unificar-por-nombre", "mantener-separada"]
        }
      }
    },
    "estado_s": {
      "type": "string",
      "enum": ["S0", "S1", "S2", "S3", "S4", "S5", "S6", "S7"],
      "$comment": "estados de entrega ISO 19650 (flujo del CDE)"
    },
    "ids_pack": {
      "type": "object",
      "required": ["id", "version"],
      "additionalProperties": true,
      "properties": {
        "familia": { "type": "string", "const": "ids" },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
